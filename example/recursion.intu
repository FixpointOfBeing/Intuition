let rec factorial (n : Int) : Int =
  if n == 0
  then 1
  else n * factorial (n - 1)
in

let rec fib (n : Int) : Int =
  if n <= 1
  then n
  else fib (n - 1) + fib (n - 2)
in

let rec power (base : Int) (exp : Int) : Int =
  if exp == 0
  then 1
  else base * power base (exp - 1)
in

let rec sum_to (n : Int) : Int =
  if n == 0
  then 0
  else n + sum_to (n - 1)
in

sum_to 100
